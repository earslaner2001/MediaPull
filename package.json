{
  "name": "mediapull",
  "version": "2.0.5",
  "description": "Twitter, YouTube ve desteklenen kaynaklardan medya indirme.",
  "author": "MediaPull",
  "main": "main.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && electron-builder --win",
    "start": "electron .",
    "dev": "cross-env MEDIAPULL_DEV=1 electron ."
  },
  "build": {
    "appId": "com.mediapull.app",
    "productName": "MediaPull",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!downloads",
      "!binaries"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MediaPull",
      "include": "uninstall.nsh",
      "deleteAppDataOnUninstall": true
    },
    "asar": true
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^26.0.12",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.9.0",
    "progress": "^2.0.3"
  }
}
